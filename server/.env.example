# server/.env.example
# Copy this file to .env and fill in the values

NODE_ENV=development
PORT=5000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zardb?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# MinIO (file storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zartsa

# ZIMS (vehicle verification)
ZIMS_API_URL=http://localhost:6000
ZIMS_API_KEY=your-zims-api-key

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# OTP
OTP_EXPIRES_IN=300

# Rate limiting
RATE_LIMIT_MAX=50
RATE_LIMIT_WINDOW=3600000

# SMS Gateway (optional, for production OTP delivery)
# SMS_GATEWAY_URL=
# SMS_GATEWAY_KEY=